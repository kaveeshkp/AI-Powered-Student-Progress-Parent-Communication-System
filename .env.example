# Student Application Environment Configuration

# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/studentapp?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=

# JWT Configuration
JWT_SECRET=01234567890123456789012345678901
JWT_EXPIRATION_MS=86400000

# Security Configuration
ENFORCE_HTTPS=false
REQUIRE_SECURE_COOKIES=false
ENABLE_HSTS=false
HSTS_MAX_AGE=31536000

# CORS Configuration
CORS_ALLOWED_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*

# Logging Configuration
LOG_PATH=logs

# Server Configuration
SERVER_PORT=8080

# For Production:
# DB_USERNAME=studentuser
# DB_PASSWORD=StrongPassword123!
# JWT_SECRET=<generate with: openssl rand -base64 32>
# ENFORCE_HTTPS=true
# REQUIRE_SECURE_COOKIES=true
# ENABLE_HSTS=true
# CORS_ALLOWED_ORIGIN=https://yourdomain.com
